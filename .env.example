# Domain (used by Helm --set system.url and ingress.hostname)
SENTRY_DOMAIN=sentry.example.com

# Admin account (password >= 12 chars, used by Helm --set user.email/password)
SENTRY_ADMIN_EMAIL=sentry-admin@lhowsam.com
SENTRY_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# SSH
SSH_PORT=22

# Retention (30d keeps disk usage low on 80GB CX33)
SENTRY_EVENT_RETENTION_DAYS=30

# SMTP (for alerts, invites, password resets)
SENTRY_MAIL_FROM=noreply@example.com
SENTRY_MAIL_HOST=smtp.example.com
SENTRY_MAIL_PORT=587
SENTRY_MAIL_USERNAME=
SENTRY_MAIL_PASSWORD=
SENTRY_MAIL_USE_TLS=True

# Backups (stored at /opt/sentry/backups on the server)
BACKUP_RETENTION_DAYS=7

# Webhook for health alerts (Slack, Discord, etc.)
MONITOR_WEBHOOK_URL=

# GitHub Integration (create at https://github.com/settings/apps)
# Required for GitHub login and commit/PR linking
GITHUB_APP_ID=
GITHUB_APP_NAME=
GITHUB_APP_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY_PATH=

# Grafana (deployed via K8s monitoring manifests)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
