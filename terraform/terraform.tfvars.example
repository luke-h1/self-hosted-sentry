# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to version control.

# Hetzner Cloud API token (from https://console.hetzner.cloud)
hcloud_token = ""

# Path to your SSH public key
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# PRODUCTION: Restrict SSH to your IP(s) only
# Find your IP: curl -s https://ifconfig.me
ssh_allowed_ips = [
  # "YOUR_IP/32",
]

# SSH port
ssh_port = 22

# Keep false when routing Sentry through Cloudflare Tunnel.
allow_public_http = false

# Server configuration
# `ccx23` matches the repo's target profile: 4 dedicated vCPU, 16GB RAM, 160GB disk.
server_name     = "sentry"
server_type     = "ccx23"
server_location = "nbg1"        # nbg1 (Nuremberg), fsn1 (Falkenstein), hel1 (Helsinki)
environment     = "production"

# Volume: disabled = use the server's built-in 160GB disk.
enable_volume  = false
volume_size_gb = 50

# Cloudflare API token (from https://dash.cloudflare.com/profile/api-tokens)
# Required permissions: Zone:DNS:Edit, Zone:Zone Settings:Edit, Cloudflare Tunnel edit
cloudflare_api_token = ""
cloudflare_account_id = ""      # Optional if Terraform can infer it from the zone

# Your domain configuration
cloudflare_zone_name   = "example.com"         # Root domain in Cloudflare
cloudflare_record_name = "sentry"              # Subdomain (creates sentry.example.com)
domain                 = "sentry.example.com"  # Full domain for Sentry

# Sentry admin
sentry_admin_email = "admin@example.com"

# Cloudflare R2 Object Storage (for Sentry filestore)
# Get your account ID from: https://dash.cloudflare.com (right sidebar)
# R2 provides S3-compatible storage with zero egress fees
enable_r2           = true
r2_bucket_name      = "sentry-filestore"
r2_bucket_location  = "WEUR"
r2_account_id       = ""  # Leave empty to reuse cloudflare_account_id
r2_access_key_id    = ""  # Create in Cloudflare R2 -> Manage R2 API tokens
r2_secret_access_key = ""
